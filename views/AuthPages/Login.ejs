<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
    <link href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 30px;
        color: #222;
      }

      a {
        display: inline-block;
        margin-bottom: 25px;
        color: #2563eb;
        text-decoration: none;
      }

      /* Form */
      #login {
        margin-top: 20px;
      }

      input[type="email"],
      input[type="password"] {
        display: block;
        width: 250px;
        padding: 8px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
        margin-bottom: 10px;
      }

      /* Buttons */
      .btn {
        display: inline-block;
        padding: 8px 16px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        color: #fff;
      }

      .btn:hover {
        opacity: 0.9;
      }

      .btn-primary { background: #2563eb; }
    </style>
</head>
<body>
    <form method="post" id="login">
        <input type="email" name="email" id="email" required placeholder="Enter email">
        <input type="password" name="password" id="password" required placeholder="Enter Password">
        <input type="submit" value="Login" class="btn btn-primary"> <a href="/register">Create Account</a>
    </form> 
    <script>
        document.querySelector('#login').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const payload = Object.fromEntries(formData.entries());
        try {
        const response = await fetch('/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
                    });
        const result = await response.json();
        const msg = JSON.stringify(result.message);
        localStorage.setItem('token', JSON.stringify(result.token));
        if (!response.ok) {
        Toastify({text: result.error,duration: 10000,gravity: "top",position: "right",style: { background: "red" }}).showToast();
        console.error(`Invalid Server response : ${JSON.stringify(result)}`);
        return;
                    }
        Toastify({text: msg,duration: 10000,gravity: "top",position: "right",style: { background: "#16a34a" }}).showToast();
        window.location.href="/"

        } catch (err) {
        Toastify({text: "User side Error...",duration: 10000,gravity: "top",position: "right",style: { background: "red" }}).showToast();
        console.error(`Fetch error : ${err}`);
                }
                });
    </script>
</body>
</html>