<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration</title>
    <link
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 30px;
        color: #222;
      }

      h1 {
        margin-bottom: 5px;
      }

      a {
        display: inline-block;
        margin-bottom: 25px;
        color: #2563eb;
        text-decoration: none;
      }

      /* Form */
      #register {
        margin-top: 20px;
      }

      input[type="text"],
      input[type="email"],
      input[type="password"] {
        display: block;
        width: 250px;
        padding: 8px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
        margin-bottom: 10px;
      }

      /* Buttons */
      .btn {
        display: inline-block;
        padding: 8px 16px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        color: #fff;
      }

      .btn:hover {
        opacity: 0.9;
      }

      .btn-primary {
        background: #2563eb;
      }

      #register a {
        margin-bottom: 0;
        margin-left: 10px;
      }
    </style>
  </head>
  <body>
    <h1>Registration page</h1>
    <form method="post" id="register" enctype="multipart/form-data">
      <input
        type="text"
        name="name"
        id="name"
        required
        placeholder="Enter Full Name"
      />
      <input
        type="email"
        name="email"
        id="email"
        required
        placeholder="Enter Email"
      />
      <input
        type="password"
        name="password"
        id="password"
        required
        placeholder="Enter Password"
      />
      <input type="submit" value="Register" class="btn btn-primary" />
      <a href="/login">Login</a>
    </form>
    <script>
      document.querySelector("#register").addEventListener("submit", async (e) => {
          e.preventDefault();
          const formData = new FormData(e.target);
          const payload = Object.fromEntries(formData.entries());
          
          try {
            const response = await fetch("/registration", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            
            const result = await response.json();
            const msg = JSON.stringify(result.message);
            
            if (!response.ok) {
              if (result.errors && Array.isArray(result.errors)) {
                result.errors.forEach((errorMessage) => {
                  Toastify({
                    text: errorMessage,
                    duration: 10000,
                    gravity: "top",
                    position: "right",
                    style: { background: "red" },
                  }).showToast();
                });
              } else {
                Toastify({
                  text: result.message || "Registration failed",
                  duration: 10000,
                  gravity: "top",
                  position: "right",
                  style: { background: "red" },
                }).showToast();
              }
              
              console.error(`Invalid Server response : ${JSON.stringify(result)}`);
              return;
            }
            
            Toastify({
              text: msg.replace(/"/g, ''),
              duration: 10000,
              gravity: "top",
              position: "right",
              style: { background: "#16a34a" },
            }).showToast();

            setTimeout(() => {
              window.location.href="/";
            }, 2000);

          } catch (err) {
            Toastify({
              text: "User side Error...",
              duration: 10000,
              gravity: "top",
              position: "right",
              style: { background: "red" },
            }).showToast();
            console.error(`Fetch error : ${err}`);
          }
        });
    </script>
  </body>
</html>
